<Window x:Class="NHD_UATE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NHD_UATE"
        mc:Ignorable="d"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Closing="Window_Closing"    
        WindowStyle="None"
        WindowState="Maximized"
        Title="MainWindow" Height="799" Width="1229">

    <Viewbox>
        <Grid Margin="10">
            <Image Source="/Images/logo.png" HorizontalAlignment="Left" Height="77" Margin="26,18,0,0" VerticalAlignment="Top" Width="300"/>
            <TextBlock HorizontalAlignment="Left" Height="85" Margin="339,32,0,0" TextWrapping="Wrap" Text="UNIVERSAL MODULE TESTER" VerticalAlignment="Top" Width="725" FontSize="28" FontFamily="Arial Black" TextAlignment="Center"/>
            <GroupBox HorizontalAlignment="Left" Height="176" Header="TESTER CONFIG." Margin="-10,93,0,0" VerticalAlignment="Top" Width="336" FontSize="18" FontFamily="Arial Black">
                <Grid Height="152">
                    <!--<TextBlock Text="Display" Margin="10,20,187,0" VerticalAlignment="Top" FontSize="14" FontFamily="Segoe UI"/>
                    <ComboBox SelectedValuePath="Content" SelectionChanged="display_select_SelectionChanged" Name="display_select" HorizontalAlignment="Center" Margin="0,44,0,0" VerticalAlignment="Top" Width="304" Height="22" FontFamily="Segoe UI" FontSize="14">
                    </ComboBox>
                    -->
                    
                    <Button x:Name="Select_Display" Click="Select_Display_Click" Content="SELECT DISPLAY" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top" Padding="10" FontSize="20" FontFamily="Arial Black" Background="#FF00807D" Foreground="White" Width="304" Height="50"/>
                    <TextBlock Text="COM_A" Margin="10,74,201,0" VerticalAlignment="Top" FontSize="14" FontFamily="Segoe UI"/>
                    <ComboBox SelectedValuePath="Content" x:Name="COMA" HorizontalAlignment="Left" Margin="71,72,0,0" VerticalAlignment="Top" Width="243" Height="22" FontFamily="Segoe UI" FontSize="14"/>
                    <TextBlock Text="COM_B" Margin="10,102,201,0" VerticalAlignment="Top" FontSize="14" FontFamily="Segoe UI"/>
                    <ComboBox SelectedValuePath="Content" x:Name="COMB" HorizontalAlignment="Left" Margin="71,100,0,0" VerticalAlignment="Top" Width="243" Height="22" FontFamily="Segoe UI" FontSize="14"/>
                </Grid>
            </GroupBox>
            <GroupBox HorizontalAlignment="Left" Height="269" Header="CONSOLE" Margin="-10,427,0,0" VerticalAlignment="Top" Width="336" FontFamily="Arial Black" FontSize="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="79*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="console" Background="Black" Foreground="White" AcceptsReturn="True" HorizontalAlignment="Left" Height="221" TextWrapping="Wrap" VerticalAlignment="Center" Width="304" RenderTransformOrigin="0.235,0.57" FontSize="12" FontFamily="Consolas" Focusable="False" Grid.Column="1" Margin="2,0,0,0"/>
                </Grid>
            </GroupBox>
            <TextBlock HorizontalAlignment="Left" Height="35" Margin="339,295,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="725" FontSize="24" FontFamily="Arial Black" TextAlignment="Center"/>
            <GroupBox Name="disp_header" HorizontalAlignment="Left" Height="329" Header="DISPLAY" Margin="339,93,0,0" VerticalAlignment="Top" Width="725" FontFamily="Arial Black" FontSize="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="0*"/>
                    </Grid.ColumnDefinitions>
                    <Image x:Name="disp_image" HorizontalAlignment="Left" Height="292" Margin="1,0,0,0" Stretch="Uniform" VerticalAlignment="Center" Width="714" OpacityMask="Black" RenderTransformOrigin="0.5,0.5" StretchDirection="DownOnly" Grid.ColumnSpan="2"/>
                </Grid>
            </GroupBox>
            <GroupBox x:Name="out" HorizontalAlignment="Left" Height="252" Header="OUTPUT" Margin="339,427,0,0" VerticalAlignment="Top" Width="725" FontFamily="Arial Black" FontSize="18">
                <Grid>
                    <Image x:Name="output_image" HorizontalAlignment="Center" Height="206" Stretch="Uniform" VerticalAlignment="Center" Width="483" OpacityMask="Black" RenderTransformOrigin="0.5,0.5" StretchDirection="DownOnly"/>
                </Grid>
            </GroupBox>
            <GroupBox HorizontalAlignment="Left" Height="148" Header="MCU" Margin="-10,0,0,0" VerticalAlignment="Center" Width="336" FontSize="18" FontFamily="Arial Black">
                <Grid Height="152">
                    <Button x:Name="Test" Click="Test_Click" Content="START" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top" Padding="10" FontSize="20" FontFamily="Arial Black" Background="Green" Foreground="White" Width="304" IsEnabled="False" Height="50"/>
                    <Button x:Name="Stop" Click="Stop_Click" Content="RESET" HorizontalAlignment="Center" Margin="0,65,0,0" VerticalAlignment="Top" Padding="10" FontSize="20" FontFamily="Arial Black" Background="Red" Foreground="White" Width="304" IsEnabled="False" Height="53"/>
                </Grid>
            </GroupBox>


        </Grid>
    </Viewbox>
</Window>
