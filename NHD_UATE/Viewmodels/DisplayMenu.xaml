<Window x:Class="NHD_UATE.Viewmodels.DisplayMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NHD_UATE.Viewmodels"
        mc:Ignorable="d"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        WindowState="Maximized"
        Title="DisplayMenu" Height="450" Width="800">
    <Viewbox>
        <Border Margin="10" BorderThickness="1" BorderBrush="DimGray" CornerRadius="10">
            <Grid VerticalAlignment="Stretch" HorizontalAlignment="Center" Height="425" Width="800">
                <Grid.RowDefinitions>
                    <RowDefinition Height="350"/>
                    <RowDefinition Height="5"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" VerticalAlignment="Stretch" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="266" />
                        <ColumnDefinition Width="266" />
                        <ColumnDefinition Width="266" />
                    </Grid.ColumnDefinitions>


                    <Button x:Name="TFT_Displays" Click="TFT_Displays_Click" Grid.Column="0" Margin="10" Background="#FFE0E0E0" BorderThickness="0" FontFamily="Arial Black" FontSize="36" >
                        <TextBlock TextAlignment="Center">
            TFT <LineBreak/> Modules
                        </TextBlock>
                    </Button>
                    <Button x:Name="LCD_Displays" Click="LCD_Displays_Click" Grid.Column="1" Margin="10" Background="#FFE0E0E0" BorderThickness="0" FontFamily="Arial Black" FontSize="36" >
                        <TextBlock TextAlignment="Center">
            LCD <LineBreak/> Modules
                        </TextBlock>
                    </Button>
                    <Button x:Name="OLED_Displays" Click="OLED_Displays_Click" Grid.Column="2" Margin="10" Background="#FFE0E0E0" BorderThickness="0" FontFamily="Arial Black" FontSize="36" >
                        <TextBlock TextAlignment="Center">
            OLED <LineBreak/> Modules
                        </TextBlock>
                    </Button>
                </Grid>
                <Button x:Name="Back" Click="Back_Click" Grid.Row="1" Margin="10,10,543,-60" FontSize="20" FontFamily="Arial Black" Background="Red" Foreground="White">BACK</Button>
            </Grid>
        </Border>
    </Viewbox>
</Window>
